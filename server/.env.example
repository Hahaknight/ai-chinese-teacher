# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# WeChat AppID and Secret
WECHAT_APP_ID=your_appid
WECHAT_APP_SECRET=your_appsecret

# Tencent Cloud COS (生产环境启用)
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=ai-chinese-teacher
COS_REGION=ap-guangzhou
COS_ENABLED=false

# minimax 平台(主 AI 客户端)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_FALLBACK_MODEL=MiniMax-M2.7

# 是否走两步流水线(每张图片独立 OCR,再合并批改)
# 1: 两步流水线 OCR→批改(默认推荐,OCR 质量高,M2.7 不会幻觉)
# 0: 一步调用,直接发图片+批改要求(更快但 OCR 质量依赖批改模型)
MINIMAX_DIRECT=1

# 兼容旧配置
ANTHROPIC_API_KEY=your_minimax_api_key

# JWT
JWT_SECRET=your_jwt_secret_key_here

# 服务公开 base URL(部署到服务器时改成 https://your-domain.com)
PUBLIC_BASE_URL=