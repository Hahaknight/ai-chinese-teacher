.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #0082FF;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.category-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.category-item {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background-color: #f0f0f0;
  color: #666;
}

.category-item.active {
  background-color: #0082FF;
  color: #fff;
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.material-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.material-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.material-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background-color: #f0f5ff;
  color: #0082FF;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.material-preview {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}