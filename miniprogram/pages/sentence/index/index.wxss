.form-textarea {
  min-height: 200rpx;
}

.btn-wrapper {
  margin-top: 30rpx;
}

.result-card {
  margin-top: 30rpx;
}

.result-section {
  margin-bottom: 30rpx;
}

.result-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.result-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

.result-content.original {
  color: #999;
}

.result-content.fixed {
  color: #0082FF;
  font-weight: 600;
}

.result-content.example {
  background-color: #f5f5f5;
  padding: 16rpx;
  border-radius: 8rpx;
  font-family: monospace;
}

.btn-copy {
  background-color: #0082FF;
  color: #fff;
  margin-top: 20rpx;
}