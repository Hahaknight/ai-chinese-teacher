.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.history-content {
  margin-bottom: 16rpx;
}

.original-sentence {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.fixed-sentence {
  font-size: 28rpx;
  color: #0082FF;
  font-weight: 600;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}