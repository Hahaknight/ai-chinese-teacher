.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-input {
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 300rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn-wrapper {
  margin-top: 40rpx;
}

.prompt-presets {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.prompt-preset-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background-color: #f0f4f8;
  color: #2c5282;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.prompt-preset-btn:active {
  background-color: #e2e8f0;
}