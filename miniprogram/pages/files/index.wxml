<view class="container">
  <view class="filter-tabs">
    <view class="filter-item {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">全部</view>
    <view class="filter-item {{filterType === 'docx' ? 'active' : ''}}" bindtap="setFilter" data-type="docx">Word</view>
    <view class="filter-item {{filterType === 'pdf' ? 'active' : ''}}" bindtap="setFilter" data-type="pdf">PDF</view>
  </view>

  <view class="file-list" wx:if="{{files.length > 0}}">
    <view class="file-item" wx:for="{{files}}" wx:key="id" bindtap="openFile" data-url="{{item.fileUrl}}">
      <view class="file-icon">{{item.fileType === 'docx' ? '📄' : '📑'}}</view>
      <view class="file-info">
        <view class="file-name">{{item.fileName}}</view>
        <view class="file-meta">
          <text class="file-size">{{item.fileSizeText}}</text>
          <text class="file-time">{{item.createdAtText}}</text>
        </view>
      </view>
      <view class="file-download">打开</view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text wx:if="{{filterType === 'all'}}">暂无文件</text>
    <text wx:elif="{{filterType === 'pdf'}}">暂无 PDF 文档</text>
    <text wx:elif="{{filterType === 'docx'}}">暂无 Word 文档</text>
    <text wx:else>暂无文件</text>
  </view>
</view>