.badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.badge-pending {
  background-color: #f0f0f0;
  color: #666;
}

.badge-processing {
  background-color: #fff3e0;
  color: #ff9800;
}

.badge-completed {
  background-color: #e8f5e9;
  color: #4caf50;
}

.badge-partial {
  background-color: #fff8e1;
  color: #ffc107;
}

.badge-failed {
  background-color: #ffebee;
  color: #f44336;
}
